 showLoading, hideLoading } from 'react-redux-loading'\r\n\r\nconst AUTHED_ID = 'tylermcginnis'\r\n\r\nexport function handleInitialData () {\r\n  return (dispatch) => {\r\n    dispatch(showLoading())\r\n    return getInitialData()\r\n      .then(({ users, questions }) => {\r\n        dispatch(receiveUsers(users))\r\n        dispatch(receiveQuestions(questions))\r\n        //dispatch(setAuthedUser(AUTHED_ID))\r\n        dispatch(hideLoading())\r\n      })\r\n  }\r\n}\r\n","C:\\Users\\User\\Desktop\\For me\\React-Projects\\Udacity\\wouldyourather\\src\\components\\Form.js",["126","127","128"],"C:\\Users\\User\\Desktop\\For me\\React-Projects\\Udacity\\wouldyourather\\src\\components\\Dashboard.js",["129","130","131","132"],"C:\\Users\\User\\Desktop\\For me\\React-Projects\\Udacity\\wouldyourather\\src\\middleware\\logger.js",[],"C:\\Users\\User\\Desktop\\For me\\React-Projects\\Udacity\\wouldyourather\\src\\reducers\\users.js",["133","134"],"import {RECEIVE_USERS, ADD_USER,SIGN_IN, FAILED_SIGN_IN ,ANSWER_QUESTION_USER} from '../actions/users'\r\n\r\nexport default function users (state = {}, action) {\r\n    switch(action.type) {\r\n      case RECEIVE_USERS :\r\n        return {\r\n          ...state,\r\n          ...action.users\r\n        }\r\n    case ADD_USER :\r\n      return {\r\n        ...state,...action.user\r\n      }\r\n    case ANSWER_QUESTION_USER :\r\n    return {\r\n      ...state,...action.user\r\n    }\r\n      default :\r\n        return state\r\n    }\r\n    \r\n\r\n  }\r\n","C:\\Users\\User\\Desktop\\For me\\React-Projects\\Udacity\\wouldyourather\\src\\reducers\\questions.js",[],"C:\\Users\\User\\Desktop\\For me\\React-Projects\\Udacity\\wouldyourather\\src\\reducers\\authedUser.js",[],"C:\\Users\\User\\Desktop\\For me\\React-Projects\\Udacity\\wouldyourather\\src\\components\\MyProfile.js",["135","136","137","138","139"],"C:\\Users\\User\\Desktop\\For me\\React-Projects\\Udacity\\wouldyourather\\src\\components\\Questions.js",["140","141","142","143","144"],"C:\\Users\\User\\Desktop\\For me\\React-Projects\\Udacity\\wouldyourather\\src\\components\\Home.js",["145","146","147"],"C:\\Users\\User\\Desktop\\For me\\React-Projects\\Udacity\\wouldyourather\\src\\components\\AddQuestions.js",["148"],"C:\\Users\\User\\Desktop\\For me\\React-Projects\\Udacity\\wouldyourather\\src\\components\\QuestionModal.js",["149","150","151","152","153"],"C:\\Users\\User\\Desktop\\For me\\React-Projects\\Udacity\\wouldyourather\\src\\components\\Leaderboard.js",["154","155","156"],"C:\\Users\\User\\Desktop\\For me\\React-Projects\\Udacity\\wouldyourather\\src\\components\\Input.js",["157"],"import '../App.css';\r\nimport React, { Component } from 'react';\r\n\r\nclass Input extends React.Component{\r\n  state={\r\n    display:false\r\n  }\r\n\r\n  displayLabel=(e)=>{\r\n    e.target.placeholder=\"\"\r\n    this.setState({ display: true })\r\n  }\r\n  hideLabel=(e)=>{\r\n    if(e.target.value===\"\"){\r\n    this.setState({ display:false })\r\n    e.target.placeholder=this.props.placeholder;\r\n    }\r\n  }\r\n\r\nrender(){\r\n  return (\r\n     <div class=\"input\">\r\n        {this.state.display?<span className=\"row show\">{this.props.placeholder}</span> :<span className=\"row hide\">{this.props.placeholder}</span>}\r\n        <input placeholder={this.props.placeholder} onFocus={this.displayLabel} onBlur={this.hideLabel} type={this.props.type} onChange={this.props.onChange}/>\r\n    </div>\r\n  );\r\n}\r\n}\r\n\r\nexport default Input;\r\n","C:\\Users\\User\\Desktop\\For me\\React-Projects\\Udacity\\wouldyourather\\src\\actions\\users.js",["158","159"],"C:\\Users\\User\\Desktop\\For me\\React-Projects\\Udacity\\wouldyourather\\src\\actions\\questions.js",[],"C:\\Users\\User\\Desktop\\For me\\React-Projects\\Udacity\\wouldyourather\\src\\utils\\API.js",[],"C:\\Users\\User\\Desktop\\For me\\React-Projects\\Udacity\\wouldyourather\\src\\actions\\authedUser.js",[],"C:\\Users\\User\\Desktop\\For me\\React-Projects\\Udacity\\wouldyourather\\src\\components\\MyAnsweredQuestion.js",["160","161","162","163","164","165","166","167","168"],"import '../App.css';\r\nimport React, { Component } from 'react';\r\nimport {\r\n  NavLink,\r\n  BrowserRouter as Router,\r\n  Switch,\r\n  Route\r\n} from \"react-router-dom\";\r\n\r\nclass MyAnsweredQuestion extends React.Component{\r\n  state= {\r\n    display : false\r\n  }\r\n  createDiagram = (question) => { \r\n    const { id } = question;\r\n    const  {optionOne,optionTwo,total} = this.props.percentage;\r\n    const isZeroOptionOne = optionOne == 0 ;\r\n    const isZeroOptionTwo = optionTwo == 0 ;\r\n    const widthOfOptionOne = { width: optionOne/total * 100 + '%'}\r\n    const widthOfOptionTwo = { width: optionTwo/total * 100 + '%'}\r\n    const widthOfDiagram = this.state.display ? 'hovered' : 'notHovered'\r\n   \r\n    const diagram = <div class={ 'diagram '+ widthOfDiagram} id={id}>\r\n                      <div class=\"OptionOne\" style={widthOfOptionOne}>\r\n                       {!isZeroOptionOne &&question.optionOne.text +`(${optionOne}/${total} ${(optionOne/total*100).toFixed(2)}%)` }\r\n                      </div>\r\n                      <div class=\"OptionTwo\" style={widthOfOptionTwo}>\r\n                      {!isZeroOptionTwo && question.optionTwo.text +`(${optionTwo}/${total} ${(optionTwo/total*100).toFixed(2)}%)` }\r\n                      </div>\r\n                   </div>\r\n    return diagram\r\n  }\r\n  handleHover=(question)=>{\r\n    this.setState({ display: true });\r\n  }\r\n  handleHoverOut=(question)=>{\r\n    this.setState({ display: false });\r\n  }\r\n  render(){\r\n\r\n    const {question , percentage, user}=this.props;\r\n    const { display } = this.state;\r\n\r\n    return(\r\n              <div class='Question-box'>\r\n                  <NavLink to={'/Dashboard/MyProfile/questions/' + question.id}>\r\n                  <div class= \"Answered-Question\" onMouseEnter= {this.handleHover} onMouseLeave= {this.handleHoverOut}>\r\n                    <div class= \"Answer\">\r\n                      I would rather {question.optionOne.votes.find(question=>question==user) !== undefined ? \r\n                      `${question.optionOne.text }  than  ${question.optionTwo.text}` :\r\n                      `${question.optionTwo.text} than ${question.optionOne.text}`\r\n                      } \r\n                      </div>\r\n                    { this.createDiagram(question)}\r\n                    </div>\r\n                    </NavLink>\r\n                </div>\r\n            \r\n          )\r\n    }\r\n}\r\n\r\nexport default MyAnsweredQuestion;","C:\\Users\\User\\Desktop\\For me\\React-Projects\\Udacity\\wouldyourather\\src\\components\\UnansweredQuestions.js",["169","170","171","172","173"],"C:\\Users\\User\\Desktop\\For me\\React-Projects\\Udacity\\wouldyourather\\src\\utils\\_DATA.js",[],"C:\\Users\\User\\Desktop\\For me\\React-Projects\\Udacity\\wouldyourather\\src\\components\\LoginAgain.js",["174","175","176","177","178"],{"ruleId":"179","replacedBy":"180"},{"ruleId":"181","replacedBy":"182"},{"ruleId":"183","severity":1,"message":"184","line":6,"column":42,"nodeType":"185","messageId":"186","endLine":6,"endColumn":52},{"ruleId":"183","severity":1,"message":"187","line":45,"column":30,"nodeType":"185","messageId":"186","endLine":45,"endColumn":43},{"ruleId":"188","severity":1,"message":"189","line":53,"column":61,"nodeType":"190","endLine":53,"endColumn":78},{"ruleId":"188","severity":1,"message":"189","line":54,"column":149,"nodeType":"190","endLine":54,"endColumn":206},{"ruleId":"191","severity":1,"message":"192","line":62,"column":46,"nodeType":"193","endLine":62,"endColumn":51},{"ruleId":"183","severity":1,"message":"194","line":2,"column":17,"nodeType":"185","messageId":"186","endLine":2,"endColumn":26},{"ruleId":"183","severity":1,"message":"195","line":16,"column":19,"nodeType":"185","messageId":"186","endLine":16,"endColumn":28},{"ruleId":"183","severity":1,"message"