nt":0,"fixableWarningCount":0,"usedDeprecatedRules":"48"},{"filePath":"85","messages":"86","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"48"},{"filePath":"87","messages":"88","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"48"},{"filePath":"89","messages":"90","errorCount":0,"warningCount":4,"fixableErrorCount":0,"fixableWarningCount":0,"source":"91","usedDeprecatedRules":"48"},{"filePath":"92","messages":"93","errorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"94","usedDeprecatedRules":"48"},{"filePath":"95","messages":"96","errorCount":0,"warningCount":5,"fixableErrorCount":0,"fixableWarningCount":0,"source":"97","usedDeprecatedRules":"48"},{"filePath":"98","messages":"99","errorCount":0,"warningCount":9,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"100","messages":"101","errorCount":0,"warningCount":5,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},"C:\\Users\\vaggelakis\\Desktop\\MyProj\\wouldyourather\\wouldyourather\\src\\index.js",[],["102","103"],"C:\\Users\\vaggelakis\\Desktop\\MyProj\\wouldyourather\\wouldyourather\\src\\components\\App.js",["104","105"],"import '../App.css';\nimport logo from './images/logo.png';\nimport Form from './Form';\nimport Welcome from './Welcome.js';\nimport React, { Component, Fragment } from 'react';\nimport { BrowserRouter as Router, Route, useHistory,Redirect } from 'react-router-dom';\nimport { connect } from 'react-redux';\nimport { handleInitialData } from '../actions/shared';\nimport LoadingBar from 'react-redux-loading';\nimport Dashboard from './Dashboard';\n\n\nclass App extends Component {\n  state={\n    active:\"\",\n    curtainsOpen:false\n  }\n\n  componentDidMount() {\n\n    this.props.dispatch(handleInitialData())\n\n  }\n  curtainEffect=()=>{\n\n    this.setState({ active: \"active\", curtainsOpen : true })\n\n\n  }\n  reRenderParent=()=>{\n\n    this.forceUpdate();\n\n  }\n  changeHistoryFromComponents=()=>{\n    \n  }\n  render() {\n  const { user, failedSignIn } = this.props\n  const {active,curtainsOpen} = this.state \n  const loggedUser = user===null ? true : false ;\n  const Sign_In_Failed = failedSignIn === true ? true : false\n  return (\n      <Router>\n        <Fragment>\n          <LoadingBar />\n          <div className=\"header-container\">\n            <div className=\"header\"><img src={logo}/></div>\n          </div>\n          <div class={\"Curtain BlueColor \"+ active } />\n          <div class={\"Curtain RedColor \"+ active } />\n          <div className='container'>\n              <div>\n                  <Route path='/Login' exact>\n                    { loggedUser && <Form reRenderParent={ this.reRenderParent } failed={Sign_In_Failed }/> }\n                    { !loggedUser && <Welcome openCurtains={ this.curtainEffect }/> }\n                    { !loggedUser&& curtainsOpen && <Redirect to=\"/Dashboard\" />}\n                  </Route>\n                  <Route path='/Dashboard' >\n                  <Dashboard />\n                  </Route>\n              </div>\n          </div>\n        </Fragment>\n      </Router>\n    )\n  }\n}\n//<Nav />\n//<Route path='/Questions/:id' component={AnswerQuestions} />\n//<Route path='/add' component={AddQuestions} />\n//<Route path='/leaderboard' component={Leaderboard} />\nfunction mapStateToProps ({autheduser}) {\n  const { user, failedSignIn } = autheduser\n  return {\n     user,failedSignIn\n  }\n}\n\nexport default connect(mapStateToProps)(App)\n","C:\\Users\\vaggelakis\\Desktop\\MyProj\\wouldyourather\\wouldyourather\\src\\components\\Welcome.js",["106"],"import '../App.css';\r\nimport React, { Component } from 'react';\r\nimport { connect } from 'react-redux'\r\n\r\nclass Welcome extends React.Component{\r\n  state={\r\n    display:false\r\n  }\r\n  componentWillMount(){\r\n    setTimeout(()=>{\r\n      this.props.openCurtains()\r\n    },1000)\r\n  }\r\n  render(){\r\n\r\n    const { user }=this.props\r\n\r\n    return(\r\n\r\n      <div class=\"Welcome css-typing\"><p>Welcome { user }!</p></div>\r\n\r\n    )}\r\n}\r\nfunction mapStateToProps ({autheduser}) {\r\n  const { user } = autheduser\r\n  return {\r\n    user\r\n  }\r\n}\r\n\r\nexport default connect(mapStateToProps)(Welcome);\r\n","C:\\Users\\vaggelakis\\Desktop\\MyProj\\wouldyourather\\wouldyourather\\src\\middleware\\index.js",[],"C:\\Users\\vaggelakis\\Desktop\\MyProj\\wouldyourather\\wouldyourather\\src\\reducers\\index.js",[],"C:\\Users\\vaggelakis\\Desktop\\MyProj\\wouldyourather\\wouldyourather\\src\\components\\Form.js",["107","108","109"],"import '../App.css';\r\nimport Input from './Input';\r\nimport React, { Component } from 'react';\r\nimport { connect } from 'react-redux';\r\nimport { handleAddUser,handleCheckCredentials } from '../actions/users';\r\n\r\nclass Form extends React.Component {\r\nstate={\r\n  displaySignUp:false,\r\n  password:\"\",\r\n  username:\"\"\r\n}\r\naddActive=()=>{\r\n  this.setState({\r\n    displaySignUp:!this.state.displaySignUp\r\n  })\r\n  this.setState({\r\n    username: \"\",\r\n    passsword:\"\"\r\n  });\r\n}\r\nhandleSignUp=(event)=>{\r\n  const {password,username}=this.state;\r\n\r\n  event.preventDefault();\r\n\r\n  this.props.dispatch(handleAddUser(username,password));\r\n\r\n}\r\nhandleSignIn=(event)=>{\r\n\r\n  const {username,password}=this.state;\r\n\r\n  let tempUsername=username;\r\n\r\n  if(username===\"\"){\r\n\r\n    tempUsername=this.props.ids[0]\r\n\r\n\r\n  }\r\n\r\n  event.preventDefault();\r\n\r\n  this.props.dispatch(handleCheckCredentials( tempUsername , password ))\r\n\r\n}\r\npasswordChange=(event)=>{\r\n  this.setState({password: event.target.value});\r\n}\r\nusernameChange=(event)=>{\r\n  this.setState({username: event.target.value});\r\n}\r\noptionChange=(event)=>{\r\n  this.setState({username: event.target.value});\r\n}\r\n  render(){\r\n    const {ids}=this.props;\r\n    return (\r\n      <div>\r\n          <div class=\"Form\">\r\n            <div class=\"Label-container\">\r\n              <div className={!this.state.displaySignUp ? 'Label active' : 'Label'} onClick={this.addActive}> <a> Sign in </a> </div>\r\n              <div className={this.state.displaySignUp ? 'Label active' : 'Label'} onClick={this.addActive}> <a> Sign up </a> </div>\r\n            </div>\r\n              {!this.state.displaySignUp&&\r\n            <div class=\" input-container\">\r\n              { this.props.failed&&<div id=\"Warning\">Sign in failed</div> }\r\n              <form onSubmit={this.handleSignIn}>\r\n                <div clas=\"droplist\">\r\n                  <select name=\"users\" id=\"users\" class=\"droplist\" onChange={this.optionChange}>\r\n                    {ids.map(id=><option value={id}>{id}</option>)}\r\n                  </select>\r\n                  </div>\r\n                  <Input placeholder=\"Insert your password\" type=\"password\" onChange={this.passwordChange}/>\r\n                  <div class=\"button-container\">\r\n                      <button class=\"Button\">Log in</button>\r\n                    </div>\r\n                </form>\r\n              </div>\r\n            }\r\n            {this.state.displaySignUp&&\r\n              <div class=\"input-container\">\r\n              <form onSubmit={this.handleSignUp}>\r\n                <Input placeholder=\"Insert your username\" type=\"text\" onChange={this.usernameChange}/>\r\n                <Input placeholder=\"Insert your password\" type=\"password\" onChange={this.passwordChange}/>\r\n                <div class=\"button-container\">\r\n                  <button class=\"Button\">Sign up</button>\r\n                </div>\r\n              </form>\r\n              </div>\r\n            }\r\n          </div>\r\n    </div>\r\n  );\r\n}\r\n\r\n}\r\n\r\nfunction mapStateToProps ({ users }) {\r\n  const usersArray=Object.keys(users)\r\n  const ids=usersArray.map((user)=>(users[user].id))\r\n  return {\r\n    ids,\r\n    users\r\n  }\r\n}\r\nexport default connect(mapStateToProps)(Form)\r\n","C:\\Users\\vaggelakis\\Desktop\\MyProj\\wouldyourather\\wouldyourather\\src\\actions\\shared.js",["110"],"import { getInitialData } from '../utils/API'\r\nimport { receiveUsers } from './users'\r\nimport { receiveQuestions } from './questions'\r\nimport { showLoading, hideLoading } from 'react-redux-loading'\r\n\r\nconst AUTHED_ID = 'tylermcginnis'\r\n\r\nexport function handleInitialData () {\r\n  return (dispatch) => {\r\n    dispatch(showLoading())\r\n    return getInitialData()\r\n      .then(({ users, questions }) => {\r\n        dispatch(receiveUsers(users))\r\n        dispatch(receiveQuestions(questions))\r\n        //dispatch(setAuthedUser(AUTHED_ID))\r\n        dispatch(hideLoading())\r\n      })\r\n  }\r\n}\r\n","C:\\Users\\vaggelakis\\Desktop\\MyProj\\wouldyourather\\wouldyourather\\src\\reducers\\users.js",["111","112"],"import {RECEIVE_USERS, ADD_USER,SIGN_IN, FAILED_SIGN_IN } from '../actions/users'\r\n\r\nexport default function users (state = {}, action) {\r\n    switch(action.type) {\r\n      case RECEIVE_USERS :\r\n        return {\r\n          ...state,\r\n          ...action.users\r\n        }\r\n    case ADD_USER :\r\n      const { user } = action\r\n      return {\r\n        ...state,...user\r\n      }\r\n      default :\r\n        return state\r\n    }\r\n\r\n\r\n  }\r\n","C:\\Users\\vaggelakis\\Desktop\\MyProj\\wouldyourather\\wouldyourather\\src\\middleware\\logger.js",[],"C:\\Users\\vaggelakis\\Desktop\\MyProj\\wouldyourather\\wouldyourather\\src\\reducers\\questions.js",[],"C:\\Users\\vaggelakis\\Desktop\\MyProj\\wouldyourather\\wouldyourather\\src\\reducers\\authedUser.js",[],"C:\\Users\\vaggelakis\\Desktop\\MyProj\\wouldyourather\\wouldyourather\\src\\components\\Input.js",["113"],"import '../App.css';\r\nimport React, { Component } from 'react';\r\n\r\nclass Input extends React.Component{\r\n  state={\r\n    display:false\r\n  }\r\n\r\n  displayLabel=(e)=>{\r\n    e.target.placeholder=\"\"\r\n    this.setState({ display: true })\r\n  }\r\n  hideLabel=(e)=>{\r\n    if(e.target.value===\"\"){\r\n    this.setState({ display:false })\r\n    e.target.placeholder=this.props.placeholder;\r\n    }\r\n  }\r\n\r\nrender(){\r\n  return (\r\n     <div class=\"input\">\r\n        {this.state.display?<span className=\"row show\">{this.props.placeholder}</span> :<span className=\"row hide\">{this.props.placeholder}</span>}\r\n        <input placeholder={this.props.placeholder} onFocus={this.displayLabel} onBlur={this.hideLabel} type={this.props.type} onChange={this.props.onChange}/>\r\n    </div>\r\n  );\r\n}\r\n}\r\n\r\nexport default Input;\r\n","C:\\Users\\vaggelakis\\Desktop\\MyProj\\wouldyourather\\wouldyourather\\src\\actions\\users.js",["114","115"],"import { ADD_QUESTION, RECEIVE_QUESTIONS } from \"./questions\"\r\nimport {setAuthedUser, FailedSignIn } from \"./authedUser\"\r\nimport { saveUser,checkCredentials } from '../utils/API'\r\nimport { showLoading, hideLoading } from 'react-redux-loading'\r\n\r\nexport const RECEIVE_USERS ='RECEIVE_USERS'\r\nexport const ADD_USER = 'ADD_USER'\r\nexport const SIGN_IN = 'SIGN_IN'\r\nexport const FAILED_SIGN_IN='FAILED_SIGN_IN'\r\n\r\n\r\nexport function receiveUsers(users){\r\n    return {\r\n        type: RECEIVE_USERS,\r\n        users,\r\n    }\r\n}\r\nexport function addUser(user){\r\n    return {\r\n        type: ADD_USER,\r\n        user\r\n    }\r\n}\r\n\r\nexport function handleAddUser(id, password){\r\n  return (dispatch, getState) => {\r\n\r\n    dispatch(showLoading())\r\n\r\n    return saveUser(id,password)\r\n      .then((user) => dispatch(addUser(user)))\r\n      .then(() => dispatch(hideLoading()))\r\n  }\r\n}\r\n\r\nexport function handleCheckCredentials(id,password){\r\n    return (dispatch, getState) => {\r\n      dispatch(showLoading())\r\n      return checkCredentials(id, password)\r\n        .then( ([result,returnedID]) => result ? dispatch(setAuthedUser(returnedID)):dispatch(FailedSignIn()) )\r\n        .then(() => dispatch(hideLoading()))\r\n        }\r\n    }\r\n","C:\\Users\\vaggelakis\\Desktop\\MyProj\\wouldyourather\\wouldyourather\\src\\actions\\questions.js",["116"],"export const RECEIVE_QUESTIONS = 'RECEIVE_QUESTIONS'\r\nexport const ADD_QUESTION = 'ADD_QUESTION'\r\n\r\nexport function receiveQuestions(questions){\r\n    return {\r\n        type:RECEIVE_QUESTIONS,\r\n        questions,\r\n    }\r\n}\r\nfunction addQuestion(question){\r\n    return {\r\n        type: ADD_QUESTION,\r\n        question,\r\n    }\r\n}","C:\\Users\\vaggelakis\\Desktop\\MyProj\\wouldyourather\\wouldyourather\\src\\utils\\API.js",[],"C:\\Users\\vaggelakis\\Desktop\\MyProj\\wouldyourather\\wouldyourather\\src\\actions\\authedUser.js",[],"C:\\Users\\vaggelakis\\Desktop\\MyProj\\wouldyourather\\wouldyourather\\src\\utils\\_DATA.js",[],"C:\\Users\\vaggelakis\\Desktop\\MyProj\\wouldyourather\\wouldyourather\\src\\components\\Dashboard.js",["117","118","119","120"],"import LoadingBar from 'react-redux-loading';\r\nimport React, { Component, Fragment } from 'react';\r\nimport { connect } from 'react-redux';\r\nimport Home from './Home.js';\r\nimport Questions from './Questions.js';\r\nimport MyProfile from './MyProfile.js';\r\nimport {\r\n    NavLink,\r\n    BrowserRouter as Router,\r\n    Switch,\r\n    Route\r\n  } from \"react-router-dom\";\r\n\r\nclass Dashboard extends React.Component {\r\n\r\n\r\n    render() {\r\n        return (\r\n            <div className= \"mainDashboard\">\r\n                <div className=\"Titles\">\r\n                <NavLink to=\"../Dashboard/Home\" activeClassName=\"selected\">\r\n                    Dashboard\r\n                </NavLink>\r\n                <NavLink to=\"../Dashboard/Leaderboard\" activeClassName=\"selected\">\r\n                    Leaderboard\r\n                </NavLink>\r\n                <NavLink to=\"../Dashboard/Questions\" activeClassName=\"selected\">\r\n                    Questions\r\n                </NavLink>\r\n                <NavLink to=\"../Dashboard/addQuestions\" activeClassName=\"selected\">\r\n                    Add Questions\r\n                </NavLink>\r\n                <NavLink to=\"../Dashboard/Myprofile\" activeClassName=\"selected\">\r\n                    My Profile\r\n                </NavLink>\r\n                </div>\r\n                <Switch>\r\n                    <Route path='/Dashboard/Home'>\r\n                        <Home />\r\n                    </Route>\r\n                    <Route path='/Dashboard/Leaderboard'>\r\n                        \r\n                    </Route>\r\n                    <Route path='/Dashboard/Questions'>\r\n                        <Questions />\r\n                    </Route>\r\n                    <Route path='/Dashboard/addQuestions'>\r\n                        \r\n                    </Route>\r\n                    <Route path='/Dashboard/MyProfile'>\r\n                        <MyProfile />\r\n                    </Route>\r\n                </Switch>\r\n            </div>\r\n        )\r\n    }\r\n\r\n}\r\nfunction mapStateToProps ({autheduser}) {\r\n    const { user, failedSignIn } = autheduser\r\n    return {\r\n       user,failedSignIn\r\n    }\r\n  }\r\nexport default connect(mapStateToProps)(Dashboard)","C:\\Users\\vaggelakis\\Desktop\\MyProj\\wouldyourather\\wouldyourather\\src\\components\\Home.js",["121","122"],"import '../App.css';\r\nimport React, { Component } from 'react';\r\nimport { connect } from 'react-redux'\r\n\r\nclass Home extends React.Component{\r\n  state={\r\n    display:false\r\n  }\r\n  render(){\r\n\r\n    const { questions }=this.props\r\n\r\n    return(\r\n\r\n      <div class=\"Home Dashboard-sub\">\r\n        werwerwerwerwerwerwe\r\n      </div>\r\n\r\n    )}\r\n}\r\nfunction mapStateToProps ({autheduser}) {\r\n  const { user } = autheduser\r\n  return {\r\n    user\r\n  }\r\n}\r\n\r\nexport default connect(mapStateToProps)(Home);","C:\\Users\\vaggelakis\\Desktop\\MyProj\\wouldyourather\\wouldyourather\\src\\components\\Questions.js",["123","124","125","126","127"],"import '../App.css';\r\nimport React, { Component } from 'react';\r\nimport { connect } from 'react-redux'\r\n\r\nclass Questions extends React.Component{\r\n  state= {\r\n    display : false\r\n  }\r\n  createDiagram = (id) => { \r\n    const  {optionOne,optionTwo,total} = this.props.percentages[id];\r\n    const isZeroOptionOne = optionOne == 0 ;\r\n    const isZeroOptionTwo = optionTwo == 0 ;\r\n    const widthOfOptionOne = {\r\n      width: optionOne/total * 100 + '%'\r\n    }\r\n    const widthOfOptionTwo = {\r\n      width: optionTwo/total * 100 + '%'\r\n    }\r\n    console.log(widthOfOptionOne)\r\n    const diagram = <div class='diagram' id={id}>\r\n                      <div class=\"OptionOne\" style={widthOfOptionOne}>\r\n                       { !isZeroOptionOne && optionOne }\r\n                      </div>\r\n                      <div class=\"OptionTwo\" style={widthOfOptionTwo}>\r\n                        { !isZeroOptionTwo && optionTwo}\r\n                      </div>\r\n                   </div>\r\n    return diagram\r\n  }\r\n  \r\n  render(){\r\n\r\n    const { questions, keys, percentages }=this.props\r\n    return(\r\n\r\n      <div class=\"Questions-sub\">\r\n        <div class='Title'>\r\n          {keys.map(x=>\r\n            <div class='Question-box'>\r\n                <div class= \"Question\">\r\n                   <div class= \"OptionOne\">\r\n                      {x.optionOne.text}\r\n                    </div>\r\n                    <div class=\"Or\">\r\n                      OR\r\n                    </div>\r\n                    <div class= \"OptionTwo\">\r\n                      {x.optionTwo.text}\r\n                    </div>\r\n                  </div>\r\n                  {this.createDiagram(x.id)}\r\n              </div>\r\n            )}\r\n\r\n        </div>\r\n      </div>\r\n\r\n    )}\r\n}\r\nfunction mapStateToProps ({questions, autheduser}) {\r\n  const { user } = autheduser;\r\n  const keys=[];\r\n  const percentages = {};\r\n  for(let key in questions){\r\n    let value = questions[key];\r\n    keys.push(value)\r\n    percentages[key]={ \r\n      'optionOne': value.optionOne.votes.length,\r\n      'optionTwo': value.optionTwo.votes.length,\r\n      'total': value.optionOne.votes.length + value.optionTwo.votes.length\r\n    }\r\n  }\r\n\r\n  return {\r\n    keys, questions, percentages, user\r\n  }\r\n}\r\n\r\nexport default connect(mapStateToProps)(Questions);","C:\\Users\\vaggelakis\\Desktop\\MyProj\\wouldyourather\\wouldyourather\\src\\components\\MyProfile.js",["128","129","130","131","132","133","134","135","136"],"C:\\Users\\vaggelakis\\Desktop\\MyProj\\wouldyourather\\wouldyourather\\src\\components\\MyAnsweredQuestion.js",["137","138","139","140","141"],{"ruleId":"142","replacedBy":"143"},{"ruleId":"144","replacedBy":"145"},{"ruleId":"146","severity":1,"message":"147","line":6,"column":42,"nodeType":"148","messageId":"149","endLine":6,"endColumn":52},{"ruleId":"150","severity":1,"message":"151","line":48,"column":37,"nodeType":"152","endLine":48,"endColumn":54},{"ruleId":"146","severity":1,"message":"153","line":2,"column":17,"nodeType":"148","messageId":"149","endLine":2,"endColumn":26},{"ruleId":"146","severity":1,"message":"153","line":3,"column":17,"nodeType":"148","messageId":"149","endLine":3,"endColumn":26},{"ruleId":"154","severity":1,"message":"155","line":63,"column":111,"nodeType":"152","endLine":63,"endColumn":114},{"ruleId":"154","severity":1,"message":"155","line":64,"column":110,"nodeType":"152","endLine":64,"endColumn":113},{"ruleId":"146","severity":1,"message":"156","line":6,"column":7,"nodeType":"148","messageId":"149","endLine":6,"endColumn":16},{"ruleId":"146","severity":1,"message":"157","line":1,"column":33,"nodeType":"148","messageId":"149","endLine":1,"endColumn":40},{"ruleId":